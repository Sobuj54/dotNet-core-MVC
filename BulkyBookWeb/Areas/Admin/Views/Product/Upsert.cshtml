@using BulkyBook.Models.ViewModel;
@model ProductVM;

<div class="container-fluid">
    <a asp-controller="Product" asp-action="Index" class="text-decoration-none text-secondary small fw-medium d-inline-flex align-items-center gap-1 mb-3">
        <i class="bi bi-arrow-left"></i> Back to products
    </a>
    <div class="card border shadow-sm overflow-hidden">
        <div class="card-header text-white py-3 px-4" style="background: linear-gradient(to right, #065f46, #282828, #191414);">
            <h5 class="mb-0 fw-bold"><i class="bi bi-plus-lg me-2"></i>@(Model.Product.Id != 0 ? "Update Product" : "Create Product")</h5>
            <p class="mb-0 small" style="color: #1DB954;">@(Model.Product.Id != 0 ? "Update a Product" : "Add a new product")</p>
        </div>
        <div class="card-body p-4">
            <form method="post" enctype="multipart/form-data">
                 <div class="row">
                    <div class="col-lg-8">
                        <div asp-validation-summary="ModelOnly"></div>
                        <input asp-for="Product.Id" hidden/>
                        <div class="row g-3">
                            <div class="col-12">
                                <label asp-for="Product.Title" class="form-label fw-semibold small">Product Name</label>
                                <input type="text" asp-for="Product.Title" class="form-control" placeholder="Enter product name" />
                                <span class="text-danger small" asp-validation-for="Product.Title"></span>
                            </div>
                            <div class="col-12">
                                <label asp-for="Product.Description" class="form-label fw-semibold small">Description</label>
                                <input type="text" asp-for="Product.Description" class="form-control" placeholder="Description" />
                                <span class="text-danger small" asp-validation-for="Product.Description"></span>
                            </div>
                            <div class="col-6">
                                <label asp-for="Product.ISBN" class="form-label fw-semibold small">ISBN</label>
                                <input type="text" asp-for="Product.ISBN" class="form-control" placeholder="ISBN" />
                                <span class="text-danger small" asp-validation-for="Product.ISBN"></span>
                            </div>
                            <div class="col-6">
                                <label asp-for="Product.Author" class="form-label fw-semibold small">Author</label>
                                <input type="text" asp-for="Product.Author" class="form-control" placeholder="Author" />
                                <span class="text-danger small" asp-validation-for="Product.Author"></span>
                            </div>
                        </div>
                        <div class="border rounded p-3 mt-3">
                            <div class="row g-3">
                                <div class="col-6 col-md-3">
                                    <label asp-for="Product.ListPrice" class="form-label fw-semibold small">List Price</label>
                                    <input type="text" asp-for="Product.ListPrice" class="form-control" />
                                    <span class="text-danger small" asp-validation-for="Product.ListPrice"></span>
                                </div>
                                <div class="col-6 col-md-3">
                                    <label asp-for="Product.Price" class="form-label fw-semibold small">Price</label>
                                    <input type="text" asp-for="Product.Price" class="form-control" />
                                    <span class="text-danger small" asp-validation-for="Product.Price"></span>
                                </div>
                                <div class="col-6 col-md-3">
                                    <label asp-for="Product.Price50" class="form-label fw-semibold small">Price 50+</label>
                                    <input type="text" asp-for="Product.Price50" class="form-control" />
                                    <span class="text-danger small" asp-validation-for="Product.Price50"></span>
                                </div>
                                <div class="col-6 col-md-3">
                                    <label asp-for="Product.Price100" class="form-label fw-semibold small">Price 100+</label>
                                    <input type="text" asp-for="Product.Price100" class="form-control" />
                                    <span class="text-danger small" asp-validation-for="Product.Price100"></span>
                                </div>
                            </div>
                        </div>
                        <div class="mt-3">
                            <div class="col-6 col-md-3">
                                <label asp-for="Product.CategoryId" class="form-label fw-semibold small"></label>
                                <select asp-for="Product.CategoryId" asp-items="@Model.CategoryList" class="form-control">
                                    <option disabled selected>Select category</option>
                                </select>
                                <span class="text-danger small" asp-validation-for="Product.CategoryId"></span>
                            </div>
                        </div>
                        <div class="mt-3">
                            <label class="form-label fw-semibold small">Product Image</label>
                            <div class="border border-2">
                                <i class="bi bi-cloud-upload fs-4 text-secondary p-4 text-center"></i>
                                <input type="file" name="file" asp-for="Product.ImageUrl" accept="image/*" class="form-control form-control-sm mt-2"/>
                                <p class="text-secondary mt-1">Upload an image</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-4">
                        @* Image *@
                        @if (!string.IsNullOrEmpty(Model.Product.ImageUrl))
                            {
                            <div class="border rounded text-center">
                                <img src="@Model.Product.ImageUrl" />
                            </div>
                            }
                            else
                            {
                                <div class="text-center text-danger">No image found.</div>
                            }
                        </div>
                </div>
                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-accent fw-semibold">@(Model.Product.Id != 0 ? "Edit" : "Create")</button>
                    <a asp-controller="Product" asp-action="Index" class="btn btn-light fw-medium">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}
