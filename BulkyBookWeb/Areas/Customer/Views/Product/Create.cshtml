@using BulkyBook.Models;
@model Product;
@{
    ViewData["title"] = "Create Product";
}

<div class="container-fluid">
    <a asp-controller="Product" asp-action="Index" class="text-decoration-none text-secondary small fw-medium d-inline-flex align-items-center gap-1 mb-3">
        <i class="bi bi-arrow-left"></i> Back to products
    </a>
    <div class="card border shadow-sm overflow-hidden">
        <div class="card-header text-white py-3 px-4" style="background: linear-gradient(to right, #065f46, #282828, #191414);">
            <h5 class="mb-0 fw-bold"><i class="bi bi-plus-lg me-2"></i>Create Product</h5>
            <p class="mb-0 small" style="color: #1DB954;">Add a new product for your products</p>
        </div>
        <div class="card-body p-4">
            <div asp-validation-summary="ModelOnly"></div>
            <form method="post">
                <div class="mb-3">
                    <label asp-for="Title" class="form-label fw-semibold small">Product Name</label>
                    <input type="text" name="Title" asp-for="@Model.Title" class="form-control" placeholder="Enter product name" />
                    <span class="text-danger small" asp-validation-for="Title"></span>
                </div>
                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-accent fw-semibold">Create Product</button>
                    <a asp-controller="Product" asp-action="Index" class="btn btn-light fw-medium">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}
